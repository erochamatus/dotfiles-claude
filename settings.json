{
  "theme": "dark",
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Write",
      "Edit",
      "mcp__chrome-devtools__take_screenshot",
      "mcp__chrome-devtools__navigate_page",
      "mcp__chrome-devtools__emulate",
      "mcp__chrome-devtools__list_pages",
      "mcp__chrome-devtools__resize_page",
      "mcp__claude_ai_Google_Drive__search_files",
      "mcp__claude_ai_Google_Drive__read_file_content",
      "mcp__mailchimp__search_campaigns",
      "mcp__mailchimp__get_campaign_details"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/sync-auto.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "elevenlabs": {
      "command": "npx",
      "args": ["-y", "@elevenlabs/elevenlabs-mcp"],
      "env": {
        "ELEVENLABS_API_KEY": "sk_e01b8b32db0fa148c6b231e3d895c283fbd0ab35c0a48f46"
      }
    }
  }
